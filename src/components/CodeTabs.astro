---
import { Code } from 'astro:components';

interface Tab {
  label: string;
  code: string;
  lang?: string;
}

interface Props {
  tabs: Tab[];
  class?: string;
}

const { tabs, class: className = '' } = Astro.props;

// Radio inputs drive the panels, so the tabs work with no JavaScript and the
// first panel is already correct on first paint. The group needs a name that is
// unique per instance; the build is static, so a random suffix is stable in the
// output.
const gid = `ct-${Math.random().toString(36).slice(2, 9)}`;

const themes = { light: 'github-light', dark: 'github-dark' };
---

<div class={`codetabs bg-surface rounded-lg border border-line/30 overflow-hidden ${className}`}>
  {tabs.map((tab, i) => (
    <input
      class="sr-only"
      type="radio"
      name={gid}
      id={`${gid}-${i}`}
      data-i={i}
      checked={i === 0}
    />
  ))}

  <div class="flex border-b border-line/30 bg-surface/80" role="tablist">
    {tabs.map((tab, i) => (
      <label
        for={`${gid}-${i}`}
        data-i={i}
        class="cursor-pointer select-none px-4 py-2 text-sm text-ink/60 border-b-2 border-transparent transition hover:text-ink"
      >
        {tab.label}
      </label>
    ))}
  </div>

  <div class="panels">
    {tabs.map((tab, i) => (
      <div class="panel" data-i={i}>
        <Code code={tab.code} lang={tab.lang ?? 'erlang'} themes={themes} defaultColor={false} />
      </div>
    ))}
  </div>
</div>

<style is:global>
  /* :has lets one generic rule light up the panel and label whose index matches
     the checked radio, instead of emitting a rule per instance. */
  .codetabs .panel {
    display: none;
  }
  .codetabs:has(input[data-i='0']:checked) .panel[data-i='0'],
  .codetabs:has(input[data-i='1']:checked) .panel[data-i='1'],
  .codetabs:has(input[data-i='2']:checked) .panel[data-i='2'],
  .codetabs:has(input[data-i='3']:checked) .panel[data-i='3'] {
    display: block;
  }

  .codetabs:has(input[data-i='0']:checked) label[data-i='0'],
  .codetabs:has(input[data-i='1']:checked) label[data-i='1'],
  .codetabs:has(input[data-i='2']:checked) label[data-i='2'],
  .codetabs:has(input[data-i='3']:checked) label[data-i='3'] {
    color: var(--ink);
    border-bottom-color: var(--color-coral);
  }

  /* Keyboard focus has to be visible: the radio itself is off-screen. */
  .codetabs:has(input[data-i='0']:focus-visible) label[data-i='0'],
  .codetabs:has(input[data-i='1']:focus-visible) label[data-i='1'],
  .codetabs:has(input[data-i='2']:focus-visible) label[data-i='2'],
  .codetabs:has(input[data-i='3']:focus-visible) label[data-i='3'] {
    outline: 2px solid var(--color-coral);
    outline-offset: -2px;
  }
</style>
