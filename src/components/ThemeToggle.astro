---
interface Props {
  label?: string;
}
const { label = 'Toggle light and dark theme' } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  aria-label={label}
  title={label}
  class="p-2 rounded-lg text-ink/70 hover:text-ink hover:bg-line/20 transition"
>
  <svg class="theme-icon-dark w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"></path>
  </svg>
  <svg class="theme-icon-light w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path stroke-linecap="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
</button>

<style>
  /* Show the icon for the theme you would switch to. */
  :global(:root[data-theme='dark']) .theme-icon-dark { display: none; }
  :global(:root[data-theme='light']) .theme-icon-light { display: none; }
</style>

<script is:inline>
  (function () {
    var button = document.getElementById('theme-toggle');
    if (!button) return;

    button.addEventListener('click', function () {
      var next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;

      try {
        localStorage.setItem('theme', next);

        // Keep the ex_doc library reference on the same theme.
        var settings = {};
        try {
          settings = JSON.parse(localStorage.getItem('ex_doc:settings')) || {};
        } catch (e) {
          settings = {};
        }
        settings.theme = next;
        localStorage.setItem('ex_doc:settings', JSON.stringify(settings));
        localStorage.setItem('night-mode', next === 'dark' ? 'true' : 'false');
      } catch (e) {
        /* the toggle still works for this page load */
      }
    });
  })();
</script>
