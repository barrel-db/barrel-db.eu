---
import '../styles/global.css';
import ThemeScript from '../components/ThemeScript.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "La base de donnees edge-AI open source pour les agents. Documents, vecteurs et blobs sous un seul id, avec recherche locale, synchronisation, chiffrement et une couche agent via REST et MCP. Concue en Europe, en Erlang." } = Astro.props;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <ThemeScript />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo-symbol-coral.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | Barrel DB</title>

    <!-- Google Fonts - Roboto -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  </head>
  <body class="bg-surface text-ink min-h-screen flex flex-col">
    <header class="border-b border-line/30">
      <nav class="container mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/fr" class="flex items-center gap-3 hover:opacity-80 transition">
          <img src="/logo-symbol-coral.svg" alt="Barrel" class="h-10 w-auto" />
          <span class="text-xl font-bold text-ink">Barrel DB</span>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/fr/products/barrel" class="text-coral hover:text-coral-dark transition font-semibold">Barrel</a>
          <!-- Products Dropdown -->
          <div class="relative group">
            <button class="text-ink/70 hover:text-ink transition flex items-center gap-1">
              Produits
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="absolute top-full left-0 mt-2 w-56 bg-surface border border-line/30 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <a href="/fr/products/barrel" class="block px-4 py-3 hover:bg-line/20 transition">
                <span class="font-medium text-coral">Barrel</span>
                <span class="block text-xs text-ink/60">Documents, vecteurs et blobs sous un seul id</span>
              </a>
              <a href="/fr/products/agents" class="block px-4 py-3 hover:bg-line/20 transition border-t border-line/20">
                <span class="font-medium text-ink">Agents &amp; MCP</span>
                <span class="block text-xs text-ink/60">Espaces, capacites, MCP</span>
              </a>
              <a href="/fr/products/sync" class="block px-4 py-3 hover:bg-line/20 transition border-t border-line/20">
                <span class="font-medium text-ink">Sync &amp; Local-first</span>
                <span class="block text-xs text-ink/60">Offline-first, client navigateur</span>
              </a>
              <a href="/fr/products/vectordb" class="block px-4 py-3 hover:bg-line/20 transition border-t border-line/20">
                <span class="font-medium text-ink">Barrel Vector</span>
                <span class="block text-xs text-ink/60">Couche vectorielle</span>
              </a>
              <a href="/fr/products/docdb" class="block px-4 py-3 hover:bg-line/20 transition border-t border-line/20">
                <span class="font-medium text-ink">Barrel Docs</span>
                <span class="block text-xs text-ink/60">Couche documentaire</span>
              </a>
            </div>
          </div>
          <a href="/fr/docs" class="text-ink/70 hover:text-ink transition">Docs</a>
          <a href="/fr/opensource" class="text-ink/70 hover:text-ink transition">Open Source</a>
          <a href="/fr/contact" class="text-ink/70 hover:text-ink transition">Contact</a>
        </div>
        <div class="flex items-center gap-3">
          <ThemeToggle label="Basculer entre theme clair et sombre" />
          <!-- Language Switcher -->
          <div class="hidden md:flex items-center border border-line/50 rounded-lg overflow-hidden">
            <a href="/" class="text-ink/60 hover:text-ink hover:bg-line/20 px-3 py-1.5 text-sm transition">EN</a>
            <span class="bg-line/30 text-ink px-3 py-1.5 text-sm font-medium">FR</span>
          </div>
          <a href="/fr/docs" class="bg-coral hover:bg-coral-dark text-white px-4 py-2 rounded-lg transition font-medium">
            Commencer
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-line/30 py-12 mt-auto">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <img src="/logo-symbol-white.svg" alt="Barrel" class="h-8 w-auto" />
              <span class="font-bold text-ink">Barrel DB</span>
            </div>
            <p class="text-ink/60 text-sm">La base de donnees edge-AI open source. Concue en Europe.</p>
          </div>
          <div>
            <h4 class="font-semibold text-ink mb-4">Produits</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/fr/products/barrel" class="text-ink/60 hover:text-ink">Barrel</a></li>
              <li><a href="/fr/products/agents" class="text-ink/60 hover:text-ink">Agents &amp; MCP</a></li>
              <li><a href="/fr/products/sync" class="text-ink/60 hover:text-ink">Sync &amp; Local-first</a></li>
              <li><a href="/fr/products/vectordb" class="text-ink/60 hover:text-ink">Barrel Vector</a></li>
              <li><a href="/fr/products/docdb" class="text-ink/60 hover:text-ink">Barrel Docs</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-ink mb-4">Open Source</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/fr/docs" class="text-ink/60 hover:text-ink">Documentation</a></li>
              <li><a href="https://github.com/barrel-db/barrel" class="text-ink/60 hover:text-ink">Barrel sur GitHub</a></li>
              <li><a href="/fr/opensource" class="text-ink/60 hover:text-ink">Tous les Projets</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-ink mb-4">Communaute</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="https://matrix.to/#/#barrel-db:matrix.org" class="text-ink/60 hover:text-ink">Chat Matrix</a></li>
              <li><a href="/fr/contact" class="text-ink/60 hover:text-ink">Contact</a></li>
              <li class="flex items-center gap-1.5 text-ink/60">
                <span>🇪🇺</span> Entreprise europeenne
              </li>
              <li class="text-ink/60">Conforme RGPD</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-line/30 mt-8 pt-8 text-center text-ink/60 text-sm">
          <p>&copy; 2026 Enki Bridge. Licence Apache 2.0.</p>
          <p class="mt-1 flex items-center justify-center gap-1.5">
            <span>🇪🇺</span> Concu en Europe
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
