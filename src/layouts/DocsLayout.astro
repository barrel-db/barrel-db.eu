---
import '../styles/global.css';
import ThemeScript from '../components/ThemeScript.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { docsNav, docsOrder, type DocSection, type DocItem } from '../data/docs-nav';

interface Heading { depth: number; slug: string; text: string; }
interface Props {
  title: string;
  description?: string;
  slug: string;
  headings?: Heading[];
  contentClass?: string;
  lang?: 'en' | 'fr';
  base?: string;
  nav?: DocSection[];
  order?: DocItem[];
}

const {
  title, description, slug, headings = [], contentClass = "docs-content",
  lang = 'en', base = '/docs', nav = docsNav, order = docsOrder,
} = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const idx = order.findIndex((i) => i.slug === slug);
const prev = idx > 0 ? order[idx - 1] : undefined;
const next = idx >= 0 && idx < order.length - 1 ? order[idx + 1] : undefined;

const t = lang === 'fr'
  ? { onThisPage: 'Sur cette page', prev: 'Precedent', next: 'Suivant' }
  : { onThisPage: 'On this page', prev: 'Previous', next: 'Next' };
const home = lang === 'fr' ? '/fr' : '/';
const mk = (path: string) => (lang === 'fr' ? `/fr${path}` : path);
const otherBase = lang === 'fr' ? '/docs' : '/fr/docs';
const otherLabel = lang === 'fr' ? 'EN' : 'FR';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <ThemeScript />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo-symbol-coral.svg" />
    <meta name="description" content={description ?? "Barrel documentation"} />
    <title>{title} | Barrel Docs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  </head>
  <body class="bg-surface text-ink min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b border-line/30 sticky top-0 z-30 bg-surface/95 backdrop-blur">
      <nav class="container mx-auto px-4 py-3 flex items-center justify-between">
        <a href={home} class="flex items-center gap-3 hover:opacity-80 transition">
          <img src="/logo-symbol-coral.svg" alt="Barrel" class="h-8 w-auto" />
          <span class="text-lg font-bold text-ink">Barrel DB</span>
          <span class="text-ink/40">/</span>
          <span class="text-ink/70">Docs</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm">
          <a href={mk('/products/barrel')} class="text-coral hover:text-coral-dark transition font-semibold">Barrel</a>
          <a href={mk('/opensource')} class="text-ink/70 hover:text-ink transition">Open Source</a>
          <a href={mk('/contact')} class="text-ink/70 hover:text-ink transition">Contact</a>
          <a href="https://github.com/barrel-db/barrel" class="text-ink/70 hover:text-ink transition">GitHub</a>
          <a href={otherBase} class="text-ink/50 hover:text-ink border border-line/40 rounded px-2 py-0.5 transition">{otherLabel}</a>
          <ThemeToggle label={lang === 'fr' ? 'Basculer entre theme clair et sombre' : 'Toggle light and dark theme'} />
        </div>
      </nav>
    </header>

    <div class="flex-1 w-full max-w-7xl mx-auto flex gap-8 px-4">
      <!-- Sidebar -->
      <aside class="hidden lg:block w-60 shrink-0 border-r border-line/20 py-8 pr-4">
        <nav class="sticky top-20 space-y-6 text-sm">
          <div id="search" class="mb-2"></div>
          {nav.map((section) => (
            <div>
              <p class="text-ink/40 uppercase text-xs font-semibold tracking-wider mb-2">{section.title}</p>
              <ul class="space-y-1">
                {section.items.map((item) => (
                  <li>
                    <a
                      href={`${base}/${item.slug}`}
                      class={`block px-2 py-1 rounded transition ${item.slug === slug ? 'bg-line/30 text-accent font-medium' : 'text-ink/70 hover:text-ink hover:bg-line/10'}`}
                    >{item.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- Content -->
      <main class="flex-1 min-w-0 py-8">
        <article class:list={[contentClass, "max-w-3xl"]} data-pagefind-body>
          <h1 class="text-4xl font-bold mb-3">{title}</h1>
          {description && <p class="text-lg text-ink/60 mb-8">{description}</p>}
          <slot />
        </article>

        <!-- Prev / Next -->
        <nav class="max-w-3xl mt-16 pt-8 border-t border-line/20 flex justify-between gap-4 text-sm">
          {prev ? (
            <a href={`${base}/${prev.slug}`} class="group flex-1 p-4 rounded-lg border border-line/30 hover:border-accent/50 transition">
              <span class="block text-ink/40 text-xs mb-1">{t.prev}</span>
              <span class="text-ink group-hover:text-accent">&larr; {prev.label}</span>
            </a>
          ) : <span class="flex-1"></span>}
          {next ? (
            <a href={`${base}/${next.slug}`} class="group flex-1 p-4 rounded-lg border border-line/30 hover:border-accent/50 transition text-right">
              <span class="block text-ink/40 text-xs mb-1">{t.next}</span>
              <span class="text-ink group-hover:text-accent">{next.label} &rarr;</span>
            </a>
          ) : <span class="flex-1"></span>}
        </nav>
      </main>

      <!-- On this page (TOC) -->
      {toc.length > 0 && (
        <aside class="hidden xl:block w-56 shrink-0 py-8">
          <div class="sticky top-20 text-sm">
            <p class="text-ink/40 uppercase text-xs font-semibold tracking-wider mb-3">{t.onThisPage}</p>
            <ul class="space-y-2 border-l border-line/20">
              {toc.map((h) => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    class={`block border-l -ml-px pl-3 py-0.5 border-transparent text-ink/60 hover:text-accent hover:border-accent transition ${h.depth === 3 ? 'pl-6' : ''}`}
                  >{h.text}</a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )}
    </div>

    <footer class="border-t border-line/30 py-6 mt-auto">
      <div class="container mx-auto px-4 text-center text-ink/50 text-sm">
        <p>&copy; 2026 Enki Bridge. Apache 2.0. &middot; <a href="/" class="hover:text-ink">barrel-db.eu</a></p>
      </div>
    </footer>

    <style is:global>
      .docs-content { line-height: 1.7; }
      .docs-content h2 {
        font-size: 1.6rem; font-weight: 700; margin: 2.5rem 0 1rem;
        padding-bottom: 0.3rem; border-bottom: 2px solid var(--color-coral);
        scroll-margin-top: 5rem;
      }
      .docs-content h3 {
        font-size: 1.25rem; font-weight: 600; margin: 2rem 0 0.75rem;
        color: var(--accent); scroll-margin-top: 5rem;
      }
      .docs-content h4 { font-size: 1.05rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
      .docs-content p { color: color-mix(in srgb, var(--ink) 80%, transparent); margin: 1rem 0; }
      .docs-content a { color: var(--color-coral); text-decoration: none; }
      .docs-content a:hover { text-decoration: underline; }
      .docs-content ul, .docs-content ol { margin: 1rem 0; padding-left: 1.5rem; color: color-mix(in srgb, var(--ink) 80%, transparent); }
      .docs-content ul { list-style: disc; }
      .docs-content ol { list-style: decimal; }
      .docs-content li { margin: 0.4rem 0; }
      .docs-content li::marker { color: var(--accent); }
      .docs-content :not(pre) > code {
        background: var(--code-bg); color: var(--code-ink); font-family: 'JetBrains Mono', monospace;
        font-size: 0.85em; padding: 0.15rem 0.4rem; border-radius: 0.3rem;
      }
      .docs-content pre {
        margin: 1.25rem 0; padding: 1rem; border-radius: 0.6rem;
        border: 1px solid color-mix(in srgb, var(--line) 30%, transparent);
        overflow-x: auto; font-size: 0.85rem;
      }
      .docs-content pre code { font-family: 'JetBrains Mono', monospace; }
      .docs-content blockquote {
        border-left: 3px solid var(--color-coral); padding-left: 1rem; margin: 1.25rem 0;
        color: color-mix(in srgb, var(--ink) 65%, transparent);
      }
      .docs-content table { width: 100%; border-collapse: collapse; margin: 1.25rem 0; font-size: 0.9rem; }
      .docs-content th, .docs-content td {
        border: 1px solid color-mix(in srgb, var(--line) 30%, transparent);
        padding: 0.5rem 0.75rem; text-align: left;
      }
      .docs-content th { background: color-mix(in srgb, var(--line) 25%, transparent); color: var(--ink); }
      .docs-content hr { border: 0; border-top: 1px solid color-mix(in srgb, var(--line) 30%, transparent); margin: 2rem 0; }

      /* Pagefind search UI, themed from the semantic slots */
      :root {
        --pagefind-ui-scale: 0.85;
        --pagefind-ui-primary: var(--accent);
        --pagefind-ui-text: var(--ink);
        --pagefind-ui-background: var(--surface-2);
        --pagefind-ui-border: color-mix(in srgb, var(--line) 45%, transparent);
        --pagefind-ui-tag: var(--line);
        --pagefind-ui-border-width: 1px;
        --pagefind-ui-border-radius: 0.5rem;
        --pagefind-ui-font: 'Roboto', sans-serif;
      }
    </style>
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (window.PagefindUI) {
          new window.PagefindUI({ element: '#search', showSubResults: true, showImages: false, resetStyles: false });
        }
      });
    </script>
  </body>
</html>
