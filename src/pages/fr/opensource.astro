---
import Layout from '../../layouts/LayoutFr.astro';

const repoBase = "https://github.com/barrel-db/barrel/tree/main/";
const docsUrl = "/docs";

const projects = [
  { name: "barrel", kind: "La base de donnees edge-AI complete", lang: "Erlang", repo: "apps/barrel",
    blurb: "La facade : documents, blobs et vecteurs sous un seul id, avec BQL, timeline et la couche agent." },
  { name: "barrel_docdb", kind: "Couche documentaire", lang: "Erlang", repo: "apps/barrel_docdb",
    blurb: "MVCC a vecteurs de version, requetes BQL, pieces jointes, flux de changements et replication." },
  { name: "barrel_vectordb", kind: "Couche vectorielle", lang: "Erlang", repo: "apps/barrel_vectordb",
    blurb: "Backends HNSW, DiskANN, FAISS et BM25 avec recherche hybride et filtrage par metadonnees." },
  { name: "barrel_embed", kind: "Bibliotheque d'embeddings", lang: "Erlang", repo: "apps/barrel_embed",
    blurb: "Embeddings a travers plusieurs fournisseurs : OpenAI, Ollama, modeles locaux, et plus." },
  { name: "barrel_rerank", kind: "Reranking", lang: "Erlang", repo: "apps/barrel_rerank",
    blurb: "Reranking par cross-encoder pour affiner les resultats de recherche." },
  { name: "barrel_crypto", kind: "Chiffrement au repos", lang: "Erlang", repo: "apps/barrel_crypto",
    blurb: "Enveloppe AES-256-GCM, derivation de cles HKDF et fournisseurs de cles enfichables." },
  { name: "barrel_spaces", kind: "Couche agent", lang: "Erlang", repo: "apps/barrel_spaces",
    blurb: "Espaces, jetons de capacite, sessions avec TTL et transferts." },
  { name: "barrel_server", kind: "Serveur REST + MCP", lang: "Erlang", repo: "apps/barrel_server",
    blurb: "Expose Barrel via HTTP (REST/JSON) et le Model Context Protocol." },
  { name: "barrel_faiss", kind: "Bindings FAISS (optionnel)", lang: "Erlang NIF", repo: "apps/barrel_faiss",
    blurb: "Bindings Erlang NIF pour FAISS. Un backend optionnel pour la couche vectorielle." },
  { name: "barrel-lite", kind: "Client navigateur", lang: "TypeScript", repo: "clients/barrel-lite",
    blurb: "Barrel offline-first dans le navigateur : sync, multi-onglets et recherche vectorielle locale." },
];
---

<Layout title="Open Source" description="Chaque projet Barrel est 100% open source sous licence Apache 2.0. Consultez le code source, contribuez et deployez ou vous voulez.">
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-5xl">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-2 mb-4">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">100% Open Source</h1>
        <p class="text-xl text-barrel-gray/60 max-w-2xl mx-auto">
          Chaque projet Barrel est sous licence Apache 2.0. Forkez, modifiez, deployez ou vous voulez.
          Nous monetisons le support et l'infrastructure geree, pas l'acces au code.
        </p>
      </div>

      <!-- Projects Grid -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-center mb-4">Projets</h2>
        <p class="text-barrel-gray/60 text-center mb-8 max-w-2xl mx-auto">
          Barrel est une base de donnees composee de bibliotheques independantes. Utilisez l'ensemble, ou juste la partie dont vous avez besoin.
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          {projects.map((p) => (
            <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 hover:border-teal-light/50 transition flex flex-col">
              <div class="mb-3">
                <h3 class="font-bold text-teal-light">{p.name}</h3>
                <span class="text-barrel-gray/50 text-xs">{p.kind}</span>
              </div>
              <p class="text-barrel-gray/70 text-sm mb-4 flex-1">{p.blurb}</p>
              <div class="flex items-center gap-2 mb-4">
                <span class="bg-teal-light/20 text-teal-light text-xs px-2 py-0.5 rounded">Apache 2.0</span>
                <span class="bg-teal-dark/30 text-barrel-gray/70 text-xs px-2 py-0.5 rounded">{p.lang}</span>
              </div>
              <div class="flex gap-2">
                <a href={repoBase + p.repo} class="flex-1 text-center bg-teal-dark/20 hover:bg-teal-dark/30 text-barrel-gray py-2 rounded-lg transition text-sm">
                  Source
                </a>
                <a href={docsUrl} class="flex-1 text-center bg-teal-light/20 hover:bg-teal-light/30 text-teal-light py-2 rounded-lg transition text-sm">
                  Docs
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- License Section -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-center mb-8">Licence Apache 2.0</h2>
        <div class="bg-barrel-black p-8 rounded-xl border border-teal-dark/30 max-w-3xl mx-auto">
          <p class="text-barrel-gray/70 mb-6">
            Chaque projet Barrel est publie sous la licence Apache, Version 2.0. Cela signifie que vous pouvez :
          </p>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-semibold text-teal-light mb-3">Vous pouvez :</h4>
              <ul class="space-y-2 text-sm text-barrel-gray/70">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-teal-light mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  Utilisation commerciale
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-teal-light mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  Modifier et distribuer
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-teal-light mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  Utilisation privee
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-teal-light mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  Utilisation de brevets accordee
                </li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold text-coral mb-3">Vous devez :</h4>
              <ul class="space-y-2 text-sm text-barrel-gray/70">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-coral mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                  Inclure la licence
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-coral mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                  Indiquer les modifications
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-coral mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                  Inclure le copyright
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Contributing Section -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-center mb-8">Contribuer</h2>
        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
            <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-barrel-gray mb-2">Documentation</h3>
            <p class="text-barrel-gray/60 text-sm">Ameliorez la doc, corrigez les typos, ajoutez des exemples</p>
          </div>
          <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
            <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-barrel-gray mb-2">Idees de Fonctionnalites</h3>
            <p class="text-barrel-gray/60 text-sm">Ouvrez des issues pour discuter de nouvelles fonctionnalites</p>
          </div>
          <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
            <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-barrel-gray mb-2">Code</h3>
            <p class="text-barrel-gray/60 text-sm">Soumettez des pull requests avec corrections et fonctionnalites</p>
          </div>
        </div>
      </div>

      <!-- Support Section -->
      <div class="bg-gradient-to-br from-teal-dark/30 via-barrel-black to-coral/10 p-8 md:p-12 rounded-2xl border border-teal-dark/50">
        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="flex-1">
            <h2 class="text-2xl font-bold mb-4">Besoin de Support ou d'Hebergement Manage ?</h2>
            <p class="text-barrel-gray/70 mb-6">
              Bien que le code soit gratuit, nous proposons du support professionnel et de l'hebergement manage pour les equipes qui ont besoin de temps de reponse garantis, d'aide au deploiement, ou qui ne souhaitent pas gerer l'infrastructure.
            </p>
            <a href="/fr/contact" class="inline-block bg-coral hover:bg-coral-dark text-white px-6 py-3 rounded-lg transition font-semibold text-center">
              Contactez-nous pour un Devis
            </a>
          </div>
          <div class="flex-shrink-0">
            <div class="bg-barrel-black/50 p-6 rounded-xl border border-teal-dark/30">
              <p class="text-sm text-barrel-gray/60 mb-4 text-center">Services Disponibles</p>
              <div class="space-y-2 text-sm">
                <div class="flex items-center gap-2 text-barrel-gray/70">
                  <span class="text-teal-light">+</span> Communaute : Issues GitHub
                </div>
                <div class="flex items-center gap-2 text-barrel-gray/70">
                  <span class="text-coral">+</span> Support Professionnel
                </div>
                <div class="flex items-center gap-2 text-barrel-gray/70">
                  <span class="text-coral">+</span> Hebergement Manage (UE)
                </div>
                <div class="flex items-center gap-2 text-barrel-gray/70">
                  <span class="text-coral">+</span> SLAs Personnalises
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
