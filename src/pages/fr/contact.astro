---
import LayoutFr from '../../layouts/LayoutFr.astro';
---

<LayoutFr title="Contact" description="Contactez l'equipe barrel-db">
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Parlons-en</h1>
        <p class="text-xl text-barrel-gray/60 max-w-2xl mx-auto">
          Questions sur les bases de donnees Barrel ? Besoin d'aide pour le deploiement ? Nous serions ravis d'echanger avec vous.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Options -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-bold mb-6">Nous Contacter</h2>

            <!-- Matrix Chat -->
            <div class="bg-barrel-black p-6 rounded-lg border border-teal-dark/30 mb-4">
              <div class="flex items-start gap-4">
                <div class="bg-coral p-3 rounded-lg">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-barrel-gray mb-1">Chat Matrix</h3>
                  <p class="text-barrel-gray/60 text-sm mb-3">Rejoignez notre salon communautaire sur Matrix.</p>
                  <a
                    href="https://matrix.to/#/#barrel-db:matrix.org"
                    class="text-coral hover:text-coral-dark text-sm font-semibold"
                  >
                    Rejoindre #barrel-db:matrix.org &rarr;
                  </a>
                </div>
              </div>
            </div>

            <!-- Email -->
            <div class="bg-barrel-black p-6 rounded-lg border border-teal-dark/30 mb-4">
              <div class="flex items-start gap-4">
                <div class="bg-teal-dark p-3 rounded-lg">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-barrel-gray mb-1">Email</h3>
                  <p class="text-barrel-gray/60 text-sm mb-3">Pour les demandes detaillees ou si vous preferez l'email.</p>
                  <a href="mailto:hello@barrel-db.eu" class="text-coral hover:text-coral-dark text-sm font-semibold">
                    hello@barrel-db.eu
                  </a>
                </div>
              </div>
            </div>

            <!-- GitHub -->
            <div class="bg-barrel-black p-6 rounded-lg border border-teal-dark/30">
              <div class="flex items-start gap-4">
                <div class="bg-teal-light p-3 rounded-lg">
                  <svg class="w-6 h-6 text-barrel-black" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-barrel-gray mb-1">Issues GitHub</h3>
                  <p class="text-barrel-gray/60 text-sm mb-3">Signalez des bugs ou demandez des fonctionnalites sur GitHub.</p>
                  <a href="https://github.com/barrel-db" class="text-coral hover:text-coral-dark text-sm font-semibold">
                    Voir les depots &rarr;
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sales CTA -->
        <div>
          <div class="bg-gradient-to-br from-teal-dark/30 to-barrel-black p-8 rounded-xl border border-coral/30">
            <h2 class="text-2xl font-bold mb-4">Solutions Enterprise</h2>
            <p class="text-barrel-gray/80 mb-6">
              Besoin de SLAs personnalises, d'un support dedie ou d'aide pour des deploiements a grande echelle ? Discutons-en.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-2 text-barrel-gray/80">
                <svg class="w-5 h-5 text-teal-light flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>SLAs et contrats de support personnalises</span>
              </li>
              <li class="flex items-start gap-2 text-barrel-gray/80">
                <svg class="w-5 h-5 text-teal-light flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Conseil en architecture</span>
              </li>
              <li class="flex items-start gap-2 text-barrel-gray/80">
                <svg class="w-5 h-5 text-teal-light flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Assistance au deploiement</span>
              </li>
              <li class="flex items-start gap-2 text-barrel-gray/80">
                <svg class="w-5 h-5 text-teal-light flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Options cloud prive ou on-premise</span>
              </li>
            </ul>
            <a
              href="mailto:hello@barrel-db.eu?subject=Solutions%20Enterprise"
              class="block w-full bg-coral hover:bg-coral-dark text-white py-3 rounded-lg transition font-semibold text-center"
            >
              Contacter les Ventes
            </a>
          </div>

          <!-- Company Info -->
          <div class="mt-8 bg-barrel-black p-6 rounded-lg border border-teal-dark/30">
            <h3 class="font-semibold text-barrel-gray mb-4">Informations Entreprise</h3>
            <div class="space-y-2 text-sm text-barrel-gray/60">
              <p><strong class="text-barrel-gray/80">Developpe par :</strong> Enki Bridge</p>
              <p><strong class="text-barrel-gray/80">Infrastructure :</strong> <a href="https://bgp.tools/as/209823" class="text-teal-light hover:underline">AS209823</a></p>
              <p><strong class="text-barrel-gray/80">Localisation :</strong> Union Europeenne</p>
              <p><strong class="text-barrel-gray/80">Centres de Donnees :</strong> Paris, Amsterdam, Geneve, Lille</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</LayoutFr>
