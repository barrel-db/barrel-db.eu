---
import LayoutFr from '../../layouts/LayoutFr.astro';
---

<LayoutFr title="Bases de Donnees IA-Natives Open Source">
  <!-- Hero Section -->
  <section class="py-24 px-4 bg-gradient-to-b from-barrel-black to-teal-dark/10">
    <div class="container mx-auto text-center max-w-5xl">
      <div class="flex items-center justify-center gap-4 mb-6">
        <div class="flex items-center gap-2 bg-teal-dark/20 px-3 py-1.5 rounded-full border border-teal-dark/30">
          <svg class="w-4 h-4 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          <span class="text-teal-light text-sm font-medium">Open Source</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">🇪🇺</span>
          <span class="text-barrel-gray/60 text-sm font-medium uppercase tracking-wider">Europeen</span>
        </div>
      </div>
      <h1 class="text-5xl md:text-6xl font-bold mb-6">
        <span class="bg-gradient-to-r from-coral to-teal-light bg-clip-text text-transparent">Bases de Donnees IA-Natives</span>
        <br />
        <span class="text-barrel-gray">Concues en Europe</span>
      </h1>
      <p class="text-xl text-barrel-gray/70 mb-8 max-w-2xl mx-auto">
        Bases de donnees vectorielles et documentaires haute performance construites en Erlang. Open source, embarquables, pretes pour la production.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://docs.barrel-db.eu" class="bg-coral hover:bg-coral-dark text-white px-8 py-3 rounded-lg text-lg font-semibold transition">
          Documentation
        </a>
        <a href="https://github.com/barrel-db" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-8 py-3 rounded-lg text-lg transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Voir le Code
        </a>
      </div>
    </div>
  </section>

  <!-- Product Cards Section -->
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-5xl">
      <h2 class="text-3xl font-bold mb-4 text-center">Deux Bases de Donnees, Une Plateforme</h2>
      <p class="text-barrel-gray/60 text-center mb-12 max-w-2xl mx-auto">
        Des bases de donnees concues pour les charges de travail IA. Utilisez-les ensemble ou separement.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Barrel Vector Card -->
        <div class="bg-barrel-black p-8 rounded-xl border border-coral/30 hover:border-coral/50 transition">
          <div class="w-14 h-14 bg-coral/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
            </svg>
          </div>
          <div class="flex items-center gap-3 mb-2">
            <h3 class="text-2xl font-bold text-coral">Barrel Vector</h3>
            <span class="bg-teal-light/20 text-teal-light text-xs px-2 py-0.5 rounded font-medium">Apache 2.0</span>
          </div>
          <p class="text-barrel-gray/50 text-sm mb-4">Base de Donnees Vectorielle</p>
          <p class="text-barrel-gray/70 mb-6">
            Base de donnees vectorielle mono-noeud haute performance avec backends HNSW, FAISS, DiskANN et BM25. Parfaite pour la recherche semantique et les applications RAG.
          </p>
          <ul class="space-y-2 text-sm text-barrel-gray/70 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>Latence de recherche &lt;5ms</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>Recherche hybride (vecteur + BM25)</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>Filtrage par metadonnees</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>Embarquable en Erlang/Elixir</span>
            </li>
          </ul>
          <a href="/fr/products/vectordb" class="text-coral hover:text-coral-dark font-semibold">
            En savoir plus &rarr;
          </a>
        </div>

        <!-- Barrel Docs Card -->
        <div class="bg-barrel-black p-8 rounded-xl border border-teal-light/30 hover:border-teal-light/50 transition">
          <div class="w-14 h-14 bg-teal-light/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <div class="flex items-center gap-3 mb-2">
            <h3 class="text-2xl font-bold text-teal-light">Barrel Docs</h3>
            <span class="bg-teal-light/20 text-teal-light text-xs px-2 py-0.5 rounded font-medium">Apache 2.0</span>
          </div>
          <p class="text-barrel-gray/50 text-sm mb-4">Base de Donnees Documentaire</p>
          <p class="text-barrel-gray/70 mb-6">
            Base de donnees documentaire avec MVCC, requetes declaratives, abonnements temps reel et replication pair-a-pair. Concue pour l'edge computing et la synchronisation.
          </p>
          <ul class="space-y-2 text-sm text-barrel-gray/70 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>Latence de lecture &lt;1ms</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>Replication P2P</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>Abonnements temps reel</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>Indexation automatique des chemins</span>
            </li>
          </ul>
          <a href="/fr/products/docdb" class="text-teal-light hover:text-teal-dark font-semibold">
            En savoir plus &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Differentiators Section -->
  <section class="py-16 px-4 bg-barrel-black/50">
    <div class="container mx-auto max-w-5xl">
      <h2 class="text-3xl font-bold mb-4 text-center">Pourquoi Barrel Databases ?</h2>
      <p class="text-barrel-gray/60 text-center mb-12 max-w-2xl mx-auto">
        Construites differemment. Construites en Europe. Construites pour durer.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">Open Source</h3>
          <p class="text-barrel-gray/60 text-sm">Licence Apache 2.0. Forkez, modifiez, deployez ou vous voulez.</p>
        </div>

        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">Construit en Erlang</h3>
          <p class="text-barrel-gray/60 text-sm">VM eprouvee. Tolerante aux pannes par conception. Pas de pauses GC.</p>
        </div>

        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <span class="text-xl">🇪🇺</span>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">Made in Europe</h3>
          <p class="text-barrel-gray/60 text-sm">Entreprise europeenne. Pas de Cloud Act US. Conforme RGPD par conception.</p>
        </div>

        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">Embarquable</h3>
          <p class="text-barrel-gray/60 text-sm">Utilisez comme bibliotheque dans vos apps Erlang/Elixir. Pas de processus separe.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Powers Barrel Platform Section -->
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-5xl">
      <div class="bg-gradient-to-br from-teal-dark/30 via-barrel-black to-coral/10 p-8 md:p-12 rounded-2xl border border-teal-dark/50 relative overflow-hidden">
        <div class="absolute top-4 right-4 flex items-center gap-2 bg-barrel-black/80 px-3 py-1.5 rounded-full">
          <span class="text-xl">🇪🇺</span>
          <span class="text-barrel-gray/80 text-sm font-medium">Made in Europe</span>
        </div>

        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="flex-1">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">
              Alimente <span class="text-teal-light">Barrel Platform</span>
            </h2>
            <p class="text-barrel-gray/70 text-lg mb-6">
              Ces bases de donnees sont la fondation de Barrel Platform — reseau d'agents IA axe sur la confidentialite pour l'Europe.
              Le meme code eprouve que vous pouvez executer sur votre propre infrastructure.
            </p>
            <div class="grid grid-cols-2 gap-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-teal-dark/30 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-barrel-gray">Teste en Production</p>
                  <p class="text-barrel-gray/60 text-sm">Alimente de vrais services</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-teal-dark/30 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-barrel-gray">Confidentialite d'Abord</p>
                  <p class="text-barrel-gray/60 text-sm">RGPD par conception</p>
                </div>
              </div>
            </div>
          </div>

          <div class="flex-shrink-0">
            <div class="bg-barrel-black/50 p-6 rounded-xl border border-teal-dark/30 text-center">
              <p class="text-sm text-barrel-gray/60 mb-4">Besoin d'aide ?</p>
              <a href="/fr/contact" class="inline-block bg-coral hover:bg-coral-dark text-white px-6 py-3 rounded-lg font-semibold transition">
                Contactez-nous
              </a>
              <p class="text-xs text-barrel-gray/50 mt-4">Support & hebergement manage<br/>disponibles sur demande</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Open Source Section -->
  <section class="py-16 px-4 bg-barrel-black/50">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-4">100% Open Source</h2>
      <p class="text-barrel-gray/60 mb-8 max-w-2xl mx-auto">
        Tous les composants sont sous licence Apache 2.0. Forkez, modifiez, deployez ou vous voulez.
        Pas de verrouillage, pas de frais d'utilisation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://github.com/barrel-db/barrel_vectordb" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-6 py-3 rounded-lg transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Barrel Vector
        </a>
        <a href="https://github.com/barrel-db/barrel_docdb" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-6 py-3 rounded-lg transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Barrel Docs
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-gradient-to-t from-barrel-black to-teal-dark/10">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-4">Pret a Commencer ?</h2>
      <p class="text-barrel-gray/60 mb-8">
        Auto-hebergez gratuitement avec nos bases de donnees open source, ou contactez-nous pour l'hebergement manage.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://docs.barrel-db.eu" class="bg-coral hover:bg-coral-dark text-white px-8 py-3 rounded-lg text-lg font-semibold transition">
          Lire la Doc
        </a>
        <a href="/fr/contact" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-8 py-3 rounded-lg text-lg transition">
          Contactez-nous
        </a>
      </div>
    </div>
  </section>
</LayoutFr>
