---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Open Source Databases" description="Barrel databases are 100% open source. For commercial offerings, see Barrel Platform.">
  <section class="py-32 px-4">
    <div class="container mx-auto max-w-3xl text-center">
      <div class="w-16 h-16 bg-teal-light/20 rounded-2xl mx-auto flex items-center justify-center mb-8">
        <svg class="w-8 h-8 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
        </svg>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold mb-6">100% Open Source</h1>

      <p class="text-xl text-barrel-gray/70 mb-8 max-w-2xl mx-auto">
        Barrel Vector and Barrel Docs are Apache 2.0 licensed.
        Download, fork, modify, and deploy anywhere — completely free.
      </p>

      <div class="bg-barrel-black rounded-xl border border-teal-dark/30 p-8 mb-12">
        <div class="grid md:grid-cols-3 gap-6 text-center">
          <div>
            <p class="text-3xl font-bold text-teal-light mb-2">Free</p>
            <p class="text-barrel-gray/60 text-sm">Forever</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-teal-light mb-2">Apache 2.0</p>
            <p class="text-barrel-gray/60 text-sm">No restrictions</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-teal-light mb-2">Self-host</p>
            <p class="text-barrel-gray/60 text-sm">Your infrastructure</p>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="https://gitlab.enki.io/barrel-db/barrel_vectordb" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-6 py-3 rounded-lg transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/></svg>
          Barrel Vector
        </a>
        <a href="https://gitlab.enki.io/barrel-db/barrel_docdb" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-6 py-3 rounded-lg transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/></svg>
          Barrel Docs
        </a>
        <a href="https://docs.barrel-db.eu" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-6 py-3 rounded-lg transition">
          Documentation
        </a>
      </div>

      <!-- Managed Hosting -->
      <p class="text-barrel-gray/60 text-sm mb-16">
        Need managed hosting? <a href="/contact" class="text-teal-light hover:underline">Contact us</a> for a quote.
      </p>

      <!-- Contact CTA -->
      <div class="bg-gradient-to-br from-coral/20 to-teal-dark/20 rounded-xl border border-coral/30 p-8">
        <h2 class="text-2xl font-bold mb-4">Questions?</h2>
        <p class="text-barrel-gray/70 mb-6">
          Need help getting started, or want to discuss support and managed hosting options?
        </p>
        <a href="/contact" class="inline-block bg-coral hover:bg-coral-dark text-white px-8 py-3 rounded-lg font-semibold transition">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
