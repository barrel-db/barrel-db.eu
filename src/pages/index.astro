---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AI-Native Databases for Europe">
  <!-- Hero Section -->
  <section class="py-24 px-4 bg-gradient-to-b from-barrel-black to-teal-dark/10">
    <div class="container mx-auto text-center max-w-5xl">
      <div class="flex items-center justify-center gap-2 mb-6">
        <span class="text-2xl">🇪🇺</span>
        <span class="text-barrel-gray/60 text-sm font-medium uppercase tracking-wider">European Infrastructure</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-bold mb-6">
        <span class="bg-gradient-to-r from-coral to-teal-light bg-clip-text text-transparent">AI-Native Databases</span>
        <br />
        <span class="text-barrel-gray">for Europe</span>
      </h1>
      <p class="text-xl text-barrel-gray/70 mb-8 max-w-2xl mx-auto">
        High-performance vector and document databases built in Erlang. Open source, embeddable, production-ready.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://docs.barrel-db.eu" class="bg-coral hover:bg-coral-dark text-white px-8 py-3 rounded-lg text-lg font-semibold transition">
          Documentation
        </a>
        <a href="/pricing" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-8 py-3 rounded-lg text-lg transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Product Cards Section -->
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-5xl">
      <h2 class="text-3xl font-bold mb-4 text-center">Two Databases, One Platform</h2>
      <p class="text-barrel-gray/60 text-center mb-12 max-w-2xl mx-auto">
        Purpose-built databases for AI workloads. Use them together or separately.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Barrel Vector Card -->
        <div class="bg-barrel-black p-8 rounded-xl border border-coral/30 hover:border-coral/50 transition">
          <div class="w-14 h-14 bg-coral/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-2 text-coral">Barrel Vector</h3>
          <p class="text-barrel-gray/50 text-sm mb-4">Vector Database</p>
          <p class="text-barrel-gray/70 mb-6">
            High-performance single-node vector database with HNSW, FAISS, DiskANN, and BM25 backends. Perfect for semantic search and RAG applications.
          </p>
          <ul class="space-y-2 text-sm text-barrel-gray/70 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>&lt;5ms search latency</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>Hybrid search (vector + BM25)</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>Metadata filtering</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-coral">+</span>
              <span>Embeddable in Erlang/Elixir</span>
            </li>
          </ul>
          <a href="/products/vectordb" class="text-coral hover:text-coral-dark font-semibold">
            Learn more &rarr;
          </a>
        </div>

        <!-- Barrel Docs Card -->
        <div class="bg-barrel-black p-8 rounded-xl border border-teal-light/30 hover:border-teal-light/50 transition">
          <div class="w-14 h-14 bg-teal-light/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-2 text-teal-light">Barrel Docs</h3>
          <p class="text-barrel-gray/50 text-sm mb-4">Document Database</p>
          <p class="text-barrel-gray/70 mb-6">
            Document database with MVCC, declarative queries, real-time subscriptions, and peer-to-peer replication. Built for edge computing and sync.
          </p>
          <ul class="space-y-2 text-sm text-barrel-gray/70 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>&lt;1ms read latency</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>P2P replication</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>Real-time subscriptions</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-teal-light">+</span>
              <span>Automatic path indexing</span>
            </li>
          </ul>
          <a href="/products/docdb" class="text-teal-light hover:text-teal-dark font-semibold">
            Learn more &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Differentiators Section -->
  <section class="py-16 px-4 bg-barrel-black/50">
    <div class="container mx-auto max-w-5xl">
      <h2 class="text-3xl font-bold mb-4 text-center">Why Barrel Databases?</h2>
      <p class="text-barrel-gray/60 text-center mb-12 max-w-2xl mx-auto">
        Built different. Built in Europe. Built to last.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">Open Source</h3>
          <p class="text-barrel-gray/60 text-sm">Apache 2.0 licensed. Fork it, modify it, deploy it anywhere.</p>
        </div>

        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">Built in Erlang</h3>
          <p class="text-barrel-gray/60 text-sm">Battle-tested VM. Fault-tolerant by design. No garbage collection pauses.</p>
        </div>

        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <span class="text-xl">🇪🇺</span>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">EU Hosted</h3>
          <p class="text-barrel-gray/60 text-sm">GDPR native. No US Cloud Act. Your data stays in Europe.</p>
        </div>

        <div class="bg-barrel-black p-6 rounded-xl border border-teal-dark/30 text-center">
          <div class="w-12 h-12 bg-teal-light/20 rounded-lg mx-auto flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-barrel-gray mb-2">Embeddable</h3>
          <p class="text-barrel-gray/60 text-sm">Use as a library in your Erlang/Elixir apps. No separate process needed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- European Infrastructure Section -->
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-5xl">
      <div class="bg-gradient-to-br from-teal-dark/30 via-barrel-black to-coral/10 p-8 md:p-12 rounded-2xl border border-teal-dark/50 relative overflow-hidden">
        <div class="absolute top-4 right-4 flex items-center gap-2 bg-barrel-black/80 px-3 py-1.5 rounded-full">
          <span class="text-xl">🇪🇺</span>
          <span class="text-barrel-gray/80 text-sm font-medium">Made in Europe</span>
        </div>

        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="flex-1">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">
              <span class="text-teal-light">European</span> Infrastructure
            </h2>
            <p class="text-barrel-gray/70 text-lg mb-6">
              Your data never leaves Europe. Built by a European team, hosted in European data centers, operated under European law.
            </p>
            <div class="grid grid-cols-2 gap-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-teal-dark/30 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-barrel-gray">Data Sovereignty</p>
                  <p class="text-barrel-gray/60 text-sm">No US Cloud Act</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-teal-dark/30 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-barrel-gray">GDPR Native</p>
                  <p class="text-barrel-gray/60 text-sm">Built-in compliance</p>
                </div>
              </div>
            </div>
          </div>

          <div class="flex-shrink-0">
            <div class="bg-barrel-black/50 p-6 rounded-xl border border-teal-dark/30">
              <p class="text-sm text-barrel-gray/60 mb-4 text-center">Data Centers</p>
              <div class="grid grid-cols-2 gap-3">
                <div class="bg-teal-dark/20 px-4 py-3 rounded-lg text-center">
                  <p class="text-lg">🇫🇷</p>
                  <p class="font-semibold text-barrel-gray text-sm">Paris</p>
                </div>
                <div class="bg-teal-dark/20 px-4 py-3 rounded-lg text-center">
                  <p class="text-lg">🇳🇱</p>
                  <p class="font-semibold text-barrel-gray text-sm">Amsterdam</p>
                </div>
                <div class="bg-teal-dark/20 px-4 py-3 rounded-lg text-center">
                  <p class="text-lg">🇨🇭</p>
                  <p class="font-semibold text-barrel-gray text-sm">Geneva</p>
                </div>
                <div class="bg-teal-dark/20 px-4 py-3 rounded-lg text-center">
                  <p class="text-lg">🇫🇷</p>
                  <p class="font-semibold text-barrel-gray text-sm">Lille</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Open Source Section -->
  <section class="py-16 px-4 bg-barrel-black/50">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-4">100% Open Source</h2>
      <p class="text-barrel-gray/60 mb-8 max-w-2xl mx-auto">
        All components are Apache 2.0 licensed. Fork it, modify it, deploy it anywhere.
        We monetize support and managed infrastructure, not code access.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://codeberg.org/barrel-platform/barrel_vectordb" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-6 py-3 rounded-lg transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1C5.925 1 1 5.925 1 12s4.925 11 11 11 11-4.925 11-11S18.075 1 12 1zm0 1.5c5.247 0 9.5 4.253 9.5 9.5s-4.253 9.5-9.5 9.5S2.5 17.247 2.5 12 6.753 2.5 12 2.5zm0 3a6.5 6.5 0 100 13 6.5 6.5 0 000-13zm0 2a4.5 4.5 0 110 9 4.5 4.5 0 010-9z"/></svg>
          Barrel Vector
        </a>
        <a href="https://codeberg.org/barrel-platform/barrel_docdb" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-6 py-3 rounded-lg transition flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1C5.925 1 1 5.925 1 12s4.925 11 11 11 11-4.925 11-11S18.075 1 12 1zm0 1.5c5.247 0 9.5 4.253 9.5 9.5s-4.253 9.5-9.5 9.5S2.5 17.247 2.5 12 6.753 2.5 12 2.5zm0 3a6.5 6.5 0 100 13 6.5 6.5 0 000-13zm0 2a4.5 4.5 0 110 9 4.5 4.5 0 010-9z"/></svg>
          Barrel Docs
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-gradient-to-t from-barrel-black to-teal-dark/10">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-barrel-gray/60 mb-8">
        Self-host free, or get managed hosting and support with our EU infrastructure.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/pricing" class="bg-coral hover:bg-coral-dark text-white px-8 py-3 rounded-lg text-lg font-semibold transition">
          View Pricing
        </a>
        <a href="/contact" class="border border-teal-dark/50 hover:border-teal-light text-barrel-gray px-8 py-3 rounded-lg text-lg transition">
          Talk to Us
        </a>
      </div>
    </div>
  </section>
</Layout>
